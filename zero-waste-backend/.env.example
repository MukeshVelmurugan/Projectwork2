# ========================================
# ENVIRONMENT VARIABLES
# ========================================
# Copy this file to .env and fill in your values

# Server Port
PORT=5000

# MongoDB Connection String
# For Local MongoDB: mongodb://localhost:27017/zero-waste
# For MongoDB Atlas: mongodb+srv://<username>:<password>@cluster.mongodb.net/zero-waste
MONGODB_URI=mongodb://localhost:27017/zero-waste

# JWT Secret Key (Use a random string for security)
# You can generate one using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Node Environment
NODE_ENV=development
